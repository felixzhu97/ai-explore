@startuml C4-Deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

LAYOUT_WITH_LEGEND()

title Deployment Diagram - Local Development Environment

' ============================================================
' DEVELOPER WORKSTATION — the local machine
' ============================================================
Person_Ext(user, "User", "Uses the Angular web application from a browser")

' ============================================================
' RUNTIME NODES — Docker, JDK, Node
' ============================================================
Deployment_Node(developer_machine, "Developer Workstation", "localhost") {

    ' Docker Engine runs PostgreSQL + pgvector
    Deployment_Node(docker_engine, "Docker Engine", "Docker") {
        ContainerDb(postgresql, "PostgreSQL", "pgvector/pgvector:pg17", "Documents, vectors, metadata", "5432")
    }

    ' Java / Gradle — Spring Boot backend
    Deployment_Node(java_runtime, "Gradle / JDK 25", "JDK 25") {
        Container(backend, "Spring Boot 3.5 Backend", "eclipse-temurin:25-jre-alpine", "REST / SSE API", "9000")
    }

    ' Node.js / pnpm — Angular frontend
    Deployment_Node(node_runtime, "Node.js 24 + pnpm", "Node 24") {
        Container(angular_dev, "Angular 19 Dev Server", "Angular CLI", "Web UI (proxy.conf.json routes /api)", "4200")
    }
}

' ============================================================
' EXTERNAL SYSTEMS
' ============================================================
Deployment_Node(deepseek, "DeepSeek API", "HTTPS") {
    Container_Ext(deepseek_svc, "DeepSeek API", "REST", "LLM chat and Text Embedding")
}

' ============================================================
' RELATIONSHIPS
' ============================================================

' User (external) interacts with Angular in the browser
Rel(user, angular_dev, "Browses (HTTP)", "TCP")

' Angular to Spring Boot (via proxy)
Rel(angular_dev, backend, "/api/* -> localhost:9000", "HTTP/SSE")

' Spring Boot to PostgreSQL
Rel(backend, postgresql, "JDBC", "TCP")

' Spring Boot to DeepSeek API
Rel_D(backend, deepseek_svc, "LLM + Embedding", "HTTPS")

SHOW_LEGEND()
@enduml
