@startuml C4-Component-Frontend
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title 组件图 (C3) - Web 前端架构

Container_Boundary(frontend, "Web Frontend") {
    
    ' 主组件
    Component(app, "App", "React 18", "主应用组件，路由和状态管理")
    
    ' 面板组件
    System_Boundary(panels, "Panels") {
        Component(supervisor_panel, "SupervisorPanel", "React", "主管智能体交互面板")
        Component(k8s_panel, "K8sPanel", "React", "Kubernetes 集群管理面板")
        Component(monitoring_panel, "MonitoringPanel", "React", "监控和指标面板")
        Component(model_panel, "ModelPanel", "React", "ML 模型管理面板")
        Component(llmops_panel, "LLMOpsPanel", "React", "LLMOps 操作面板")
        Component(aiops_panel, "AIOpsPanel", "React", "AIOps 运维面板")
        Component(vectordb_panel, "VectorDBPanel", "React", "向量数据库面板")
        Component(pipeline_panel, "PipelinePanel", "React", "流水线管理面板")
        Component(feature_panel, "FeatureStorePanel", "React", "特征存储面板")
    }
    
    ' 智能体组件
    System_Boundary(agents, "Agent Components") {
        Component(agent_chat, "AgentChat", "React + TypeScript", "通用智能体聊天组件，支持 SSE 流式响应")
        Component(chat_message, "ChatMessage", "React", "聊天消息展示组件")
        Component(status_badge, "StatusBadge", "React", "状态徽章组件")
        Component(tool_result, "ToolResult", "React", "工具执行结果展示")
    }
    
    ' 共享组件
    System_Boundary(shared, "Shared Components") {
        Component(card, "Card", "React", "卡片容器组件")
        Component(button, "Button", "React", "按钮组件")
        Component(segmented_control, "SegmentedControl", "React", "分段选择控件")
        Component(image_uploader, "ImageUploader", "React", "图片上传组件")
        Component(rag_chat, "RAGChat", "React", "RAG 聊天组件")
    }
    
    ' 基础设施
    System_Boundary(infrastructure, "Infrastructure") {
        Component(i18n, "i18n Provider", "React i18next", "国际化支持")
        Component(theme, "Theme", "CSS-in-JS", "主题配置")
        Component(api_client, "API Client", "Fetch API", "HTTP 请求封装")
    }
}

' 组件关系
Rel(app, supervisor_panel, "渲染")
Rel(app, k8s_panel, "渲染")
Rel(app, monitoring_panel, "渲染")
Rel(app, model_panel, "渲染")
Rel(app, llmops_panel, "渲染")
Rel(app, aiops_panel, "渲染")
Rel(app, vectordb_panel, "渲染")

Rel(supervisor_panel, agent_chat, "包含")
Rel(k8s_panel, agent_chat, "包含")
Rel(aiops_panel, agent_chat, "包含")
Rel(llmops_panel, agent_chat, "包含")
Rel(vectordb_panel, agent_chat, "包含")

Rel(agent_chat, chat_message, "渲染消息列表")
Rel(agent_chat, tool_result, "渲染工具结果")
Rel(agent_chat, status_badge, "显示状态")

Rel(agent_chat, api_client, "API 调用")

Rel(app, card, "使用")
Rel(app, button, "使用")
Rel(app, segmented_control, "使用")
Rel(app, image_uploader, "使用")
Rel(app, rag_chat, "渲染")

Rel(app, i18n, "国际化")
Rel(app, theme, "主题")

SHOW_LEGEND()
@enduml
