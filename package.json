{
  "name": "ai-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean",
    "prepare": "husky",
    "docker:up": "docker compose up -d",
    "java:dev": "cd apps/server-java && ./gradlew bootRun",
    "angular:dev": "cd apps/web-angular && npm start",
    "services:start": "npm run docker:up && npm run java:dev && npm run angular:dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^1.6.1"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  }
}
