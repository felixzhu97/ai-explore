{
  "name": "ai-explore",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean",
    "prepare": "husky",
    "web:dev": "cd apps/web && npm start",
    "server:dev": "export $(grep -v '^#' .env | xargs) && ./gradlew bootRun",
    "dev:all": "npm run server:dev && npm run web:dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "server:test": "./gradlew test",
    "server:test:watch": "./gradlew test --continuous",
    "server:test:coverage": "./gradlew test jacocoTestReport"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/browser": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": ">=20"
  }
}
